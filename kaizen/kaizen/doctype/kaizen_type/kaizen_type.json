{
  "name": "Kaizen Type",
  "module": "Kaizen",
  "doctype": "DocType",
  "naming_rule": "By fieldname",
  "autoname": "field:type_name",
  "description": "精益类型主数据",
  "fields": [
    {
      "fieldname": "type_name",
      "fieldtype": "Data",
      "label": "类型名称",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "description",
      "fieldtype": "Text",
      "label": "描述"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "启用",
      "default": "1"
    }
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "All", "read": 1}
  ],
  "track_changes": 1
}
