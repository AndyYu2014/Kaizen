{
  "name": "Kaizen Project",
  "module": "Kaizen",
  "doctype": "DocType",
  "naming_rule": "Expression",
  "autoname": "KZ-.YYYYMMDD.-.##",
  "description": "改善项目 - 审核通过后正式立项的精益改善",
  "title_field": "title",
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "项目名称",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "项目状态",
      "options": "方案编制中\n实施中\n评价中\n已关闭\n已取消",
      "default": "方案编制中",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "proposal",
      "fieldtype": "Link",
      "label": "来源提案",
      "options": "Kaizen Proposal",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "kaizen_type",
      "fieldtype": "Link",
      "label": "精益类型",
      "options": "Kaizen Type",
      "in_list_view": 1
    },
    {
      "fieldname": "section_assessment",
      "fieldtype": "Section Break",
      "label": "评估信息"
    },
    {
      "fieldname": "urgency",
      "fieldtype": "Select",
      "label": "紧迫性",
      "options": "\n低\n中\n高"
    },
    {
      "fieldname": "economic_value",
      "fieldtype": "Select",
      "label": "经济性",
      "options": "\n低\n中\n高"
    },
    {
      "fieldname": "quality_impact",
      "fieldtype": "Select",
      "label": "质量影响",
      "options": "\n低\n中\n高"
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "improvement_target",
      "fieldtype": "Text",
      "label": "改进目标（人/物/财）"
    },
    {
      "fieldname": "expected_completion_date",
      "fieldtype": "Date",
      "label": "预期完成日期"
    },
    {
      "fieldname": "section_departments",
      "fieldtype": "Section Break",
      "label": "实施部门"
    },
    {
      "fieldname": "implementation_departments",
      "fieldtype": "Table",
      "label": "实施部门清单",
      "options": "Kaizen Project Department"
    },
    {
      "fieldname": "section_plan",
      "fieldtype": "Section Break",
      "label": "改善方案"
    },
    {
      "fieldname": "temporary_measure",
      "fieldtype": "Long Text",
      "label": "临时措施"
    },
    {
      "fieldname": "permanent_measure",
      "fieldtype": "Long Text",
      "label": "永久解决措施"
    },
    {
      "fieldname": "plan_start_date",
      "fieldtype": "Date",
      "label": "计划开始日期"
    },
    {
      "fieldname": "plan_end_date",
      "fieldtype": "Date",
      "label": "计划完成日期"
    },
    {
      "fieldname": "section_implement",
      "fieldtype": "Section Break",
      "label": "实施结果"
    },
    {
      "fieldname": "actual_start_date",
      "fieldtype": "Date",
      "label": "实际开始日期"
    },
    {
      "fieldname": "actual_end_date",
      "fieldtype": "Date",
      "label": "实际完成日期"
    },
    {
      "fieldname": "implementation_result",
      "fieldtype": "Long Text",
      "label": "实施效果描述"
    },
    {
      "fieldname": "result_attachments",
      "fieldtype": "Attach",
      "label": "实施结果附件（图片/视频）"
    },
    {
      "fieldname": "section_evaluate",
      "fieldtype": "Section Break",
      "label": "评价信息"
    },
    {
      "fieldname": "star_rating",
      "fieldtype": "Int",
      "label": "星级评价（1-5星）",
      "description": "5星为最高"
    },
    {
      "fieldname": "evaluator",
      "fieldtype": "Link",
      "label": "评价人",
      "options": "User",
      "read_only": 1
    },
    {
      "fieldname": "evaluate_date",
      "fieldtype": "Datetime",
      "label": "评价时间",
      "read_only": 1
    },
    {
      "fieldname": "incentive_measure",
      "fieldtype": "Text",
      "label": "激励措施"
    }
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "All", "read": 1, "write": 1}
  ],
  "track_changes": 1
}
