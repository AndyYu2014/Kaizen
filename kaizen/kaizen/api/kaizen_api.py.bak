import frappe
from frappe.utils import nowdate, add_months

def has_permission(user=None):
    return True

def has_website_permission(doc, ptype, user, verbose=False):
    return True

@frappe.whitelist(allow_guest=False)
def get_home_stats():
    user = frappe.session.user
    three_months_ago = add_months(nowdate(), -3)

    # 折线图数据
    chart_data = frappe.db.sql("""
        SELECT DATE_FORMAT(creation, '%%Y-%%m') as month,
               status, COUNT(*) as cnt
        FROM `tabKaizen Proposal`
        WHERE creation >= %(start)s AND status != '已取消'
        GROUP BY month, status ORDER BY month ASC
    """, {"start": three_months_ago}, as_dict=True)

    # 我的提案数
    my_proposals = frappe.db.count("Kaizen Proposal", {
        "submitted_by": user,
        "status": ["not in", ["已立项", "已取消"]]
    })

    # 我关联的项目数
    my_proposal_names = frappe.db.get_all(
        "Kaizen Proposal",
        filters={"submitted_by": user},
        pluck="name"
    )
    my_projects = 0
    if my_proposal_names:
        my_projects = frappe.db.count("Kaizen Project", {
            "proposal": ["in", my_proposal_names],
            "status": ["not in", ["已关闭", "已取消"]]
        })

    # 待处理数量
    pending_review = frappe.db.count("Kaizen Proposal", {"status": "已提交"})
    pending_plan = frappe.db.sql("""
        SELECT COUNT(DISTINCT kp.name) FROM `tabKaizen Project` kp
        LEFT JOIN `tabKaizen Project Department` kpd ON kpd.parent = kp.name
        WHERE kp.status = '方案编制中' AND kpd.responsible_person = %(user)s
    """, {"user": user})[0][0] or 0
    pending_implement = frappe.db.sql("""
        SELECT COUNT(DISTINCT kp.name) FROM `tabKaizen Project` kp
        LEFT JOIN `tabKaizen Project Department` kpd ON kpd.parent = kp.name
        WHERE kp.status = '实施中' AND kpd.responsible_person = %(user)s
    """, {"user": user})[0][0] or 0
    pending_evaluate = frappe.db.count("Kaizen Project", {"status": "评价中"})

    return {
        "chart_data": chart_data,
        "my_proposals": my_proposals,
        "my_projects": my_projects,
        "pending_total": pending_review + pending_plan + pending_implement + pending_evaluate,
        "pending_review": pending_review,
        "pending_plan": pending_plan,
        "pending_implement": pending_implement,
        "pending_evaluate": pending_evaluate,
    }

@frappe.whitelist(allow_guest=False)
def get_my_proposals(include_closed=0):
    user = frappe.session.user
    filters = {"submitted_by": user}
    if not int(include_closed):
        filters["status"] = ["not in", ["已立项", "已取消"]]
    proposals = frappe.get_all("Kaizen Proposal",
        filters=filters,
        fields=["name", "status", "kaizen_type", "phenomenon",
                "submitted_date", "kaizen_project", "creation"],
        order_by="creation desc", limit=50
    )
    for p in proposals:
        if p.kaizen_project:
            proj = frappe.db.get_value("Kaizen Project", p.kaizen_project, "status")
            p["project_status"] = proj or ""
            depts = frappe.get_all("Kaizen Project Department",
                filters={"parent": p.kaizen_project},
                fields=["department"], limit=3)
            p["departments"] = "、".join([d.department for d in depts])
        else:
            p["project_status"] = ""
            p["departments"] = ""
    return proposals

@frappe.whitelist(allow_guest=False)
def create_proposal(data):
    if isinstance(data, str):
        import json
        data = json.loads(data)
    from frappe.utils import now_datetime
    doc = frappe.new_doc("Kaizen Proposal")
    doc.kaizen_type = data.get("kaizen_type")
    doc.production_line = data.get("production_line")
    doc.equipment = data.get("equipment")
    doc.warehouse = data.get("warehouse")
    doc.item = data.get("item")
    doc.location_remark = data.get("location_remark")
    doc.phenomenon = data.get("phenomenon")
    doc.suggestion = data.get("suggestion")
    doc.submitted_by = frappe.session.user
    doc.status = "待提交"
    doc.insert()
    if data.get("submit_now"):
        doc.status = "已提交"
        doc.submitted_date = now_datetime()
        doc.save()
    return doc.name

@frappe.whitelist(allow_guest=False)
def submit_proposal(proposal_name):
    from frappe.utils import now_datetime
    doc = frappe.get_doc("Kaizen Proposal", proposal_name)
    doc.status = "已提交"
    doc.submitted_date = now_datetime()
    doc.save()
    return {"success": True}

@frappe.whitelist(allow_guest=False)
def get_pending_review_proposals():
    return frappe.get_all("Kaizen Proposal",
        filters={"status": "已提交"},
        fields=["name", "kaizen_type", "phenomenon", "submitted_by", "submitted_date"],
        order_by="submitted_date asc"
    )

@frappe.whitelist(allow_guest=False)
def approve_proposal(data):
    if isinstance(data, str):
        import json
        data = json.loads(data)
    from frappe.utils import now_datetime
    doc = frappe.get_doc("Kaizen Proposal", data.get("proposal_name"))
    doc.urgency = data.get("urgency")
    doc.economic_value = data.get("economic_value")
    doc.quality_impact = data.get("quality_impact")
    doc.reviewer = frappe.session.user
    doc.review_date = now_datetime()
    doc.review_comment = data.get("review_comment")
    doc.improvement_target = data.get("improvement_target")
    doc.expected_completion_date = data.get("expected_completion_date")

    project = frappe.new_doc("Kaizen Project")
    project.proposal = doc.name
    project.kaizen_type = doc.kaizen_type
    project.title = f"改善项目-{doc.name}"
    project.status = "方案编制中"
    project.urgency = doc.urgency
    project.economic_value = doc.economic_value
    project.quality_impact = doc.quality_impact
    project.improvement_target = doc.improvement_target
    project.expected_completion_date = doc.expected_completion_date
    if data.get("departments"):
        for dept in data["departments"]:
            project.append("implementation_departments", {
                "department": dept.get("department"),
                "responsible_person": dept.get("responsible_person"),
            })
    project.insert()

    doc.status = "已立项"
    doc.kaizen_project = project.name
    doc.save()
    return {"success": True, "project_name": project.name}

@frappe.whitelist(allow_guest=False)
def reject_proposal(proposal_name, reason=""):
    doc = frappe.get_doc("Kaizen Proposal", proposal_name)
    doc.status = "已取消"
    if reason:
        doc.review_comment = f"取消原因: {reason}"
    doc.save()
    return {"success": True}

@frappe.whitelist(allow_guest=False)
def get_pending_plan_projects():
    user = frappe.session.user
    return frappe.db.sql("""
        SELECT DISTINCT kp.name, kp.title, kp.status, kp.proposal, kp.expected_completion_date
        FROM `tabKaizen Project` kp
        LEFT JOIN `tabKaizen Project Department` kpd ON kpd.parent = kp.name
        WHERE kp.status = '方案编制中' AND kpd.responsible_person = %(user)s
        ORDER BY kp.creation ASC
    """, {"user": user}, as_dict=True)

@frappe.whitelist(allow_guest=False)
def submit_plan(data):
    if isinstance(data, str):
        import json
        data = json.loads(data)
    doc = frappe.get_doc("Kaizen Project", data.get("project_name"))
    doc.temporary_measure = data.get("temporary_measure")
    doc.permanent_measure = data.get("permanent_measure")
    doc.plan_start_date = data.get("plan_start_date")
    doc.plan_end_date = data.get("plan_end_date")
    doc.status = "实施中"
    doc.save()
    return {"success": True}

@frappe.whitelist(allow_guest=False)
def get_pending_implement_projects():
